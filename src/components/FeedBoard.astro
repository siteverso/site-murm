---
const { parentId = null, profileUsername = '', showRandomMurmur = true, embedded = false } = Astro.props;
const normalizedProfileUsername = String(profileUsername || '').trim().replace(/^@/, '').toLowerCase();
const feedContextKey = parentId !== null && parentId !== undefined && String(parentId) !== ''
  ? `message:${String(parentId)}`
  : normalizedProfileUsername
    ? `profile:${normalizedProfileUsername}`
    : 'home';
const configuredRandomMurmurInterval = Number.parseInt(import.meta.env.PUBLIC_HOME_RANDOM_MURMUR_INTERVAL_MS || '', 10);
const randomMurmurIntervalMs = Number.isFinite(configuredRandomMurmurInterval) && configuredRandomMurmurInterval >= 250
  ? configuredRandomMurmurInterval
  : 4000;
---
<main class:list={['minimal-feed-page', 'network-board-page', { shell: !embedded, 'feed-board--embedded': embedded }]} >
    <div class="feed-heading minimal network-board-heading">
      {showRandomMurmur && <div class="random-murmur" data-random-murmur data-random-murmur-interval-ms={randomMurmurIntervalMs} aria-live="polite">
        <div class="random-murmur__content" data-random-murmur-content hidden>
          <a class="random-murmur__user" data-random-murmur-user href="#"></a>
          <a class="random-murmur__link" data-random-murmur-link href="#">
            <span class="random-murmur__text" data-random-murmur-text></span>
          </a>
        </div>
        <span class="random-murmur__placeholder" data-random-murmur-placeholder aria-hidden="true"></span>
      </div>}
      <div class="feed-display-controls">
        <div class="segmented-control feed-view-switch" data-feed-view-switch aria-label="Modo de visualização dos murmúrios">
        <button class="segmented-control__button feed-view-button feed-view-button--deck" type="button" data-feed-view="deck" aria-label="Ver em cartas" title="Cartas">
          <svg viewBox="0 0 20 20" aria-hidden="true" fill="none">
            <rect x="5" y="3" width="11" height="14" rx="2" transform="rotate(7 5 3)" stroke="currentColor" stroke-width="1.35"/>
            <rect x="3" y="3" width="11" height="14" rx="2" transform="rotate(-4 3 3)" fill="var(--surface)" stroke="currentColor" stroke-width="1.5"/>
            <path d="M6 7h5M6 10h5M6 13h3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        </button>
        <button class="segmented-control__button feed-view-button" type="button" data-feed-view="split" aria-label="Ver em colunas" title="Colunas">
          <svg viewBox="0 0 20 20" aria-hidden="true" fill="none">
            <rect x="3" y="4" width="5" height="12" rx="1.5" stroke="currentColor" stroke-width="1.6"/>
            <rect x="12" y="4" width="5" height="12" rx="1.5" stroke="currentColor" stroke-width="1.6"/>
          </svg>
        </button>
        <button class="segmented-control__button feed-view-button feed-view-button--grid" type="button" data-feed-view="grid" aria-label="Ver em grid" title="Grid">
          <svg viewBox="0 0 20 20" aria-hidden="true" fill="none">
            <rect x="2.5" y="2.5" width="6" height="6" rx="1.35" stroke="currentColor" stroke-width="1.5"/>
            <rect x="11.5" y="2.5" width="6" height="6" rx="1.35" stroke="currentColor" stroke-width="1.5"/>
            <rect x="2.5" y="11.5" width="6" height="6" rx="1.35" stroke="currentColor" stroke-width="1.5"/>
            <rect x="11.5" y="11.5" width="6" height="6" rx="1.35" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </button>
        <button class="segmented-control__button feed-view-button" type="button" data-feed-view="list" aria-label="Ver em lista" title="Lista">
          <svg viewBox="0 0 20 20" aria-hidden="true" fill="none">
            <path d="M5 5.5h10M5 10h10M5 14.5h10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            <circle cx="3.2" cy="5.5" r=".9" fill="currentColor"/>
            <circle cx="3.2" cy="10" r=".9" fill="currentColor"/>
            <circle cx="3.2" cy="14.5" r=".9" fill="currentColor"/>
          </svg>
        </button>
        </div>
        <div class="column-group-control" data-column-group-control hidden>
          <select data-column-group-select aria-label="Escolher como dividir as colunas">
            <option value="sex">Sexo</option>
            <option value="age">Faixa etária</option>
          </select>
        </div>
      </div>
    </div>

    <section class="network-board" data-feed-board data-parent-id={parentId ?? undefined} data-profile-username={profileUsername || undefined} data-feed-context-key={feedContextKey}>
      <div class="feed-view-panel split-view" data-feed-view-panel="split" data-feed-columns></div>


      <div class="feed-view-panel grid-view" data-feed-view-panel="grid" hidden>
        <section class="network-lane all-lane">
          <div class="feed responsive-grid-feed" data-feed-grid></div>
        </section>
      </div>

      <div class="feed-view-panel deck-view" data-feed-view-panel="deck" hidden>
        <section class="network-lane all-lane deck-lane" aria-label="Murmúrios para decidir">
          <div class="card-deck" data-feed-deck tabindex="0"></div>
        </section>
      </div>

      <div class="feed-view-panel list-view" data-feed-view-panel="list" hidden>
        <section class="network-lane all-lane">
          <div class="feed lane-feed lane-feed-list" data-feed-all-list></div>
        </section>
      </div>
    </section>
  </main>
