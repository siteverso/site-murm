---
const {
  profile,
  replyGroups = [],
  backUrl = '',
  backLabel = 'Ver murmúrios',
} = Astro.props;

const normalizedGroups = replyGroups.map(group => {
  const posts = Array.isArray(group?.posts)
    ? group.posts.map(post => ({
        ...post,
        myVote: Number(post?.myVote || 0),
        replyCount: Number(post?.replyCount || 0),
      }))
    : [];

  return {
    rootPostId: Number(group?.rootPostId || 0),
    posts,
  };
});

const historyJson = JSON.stringify(normalizedGroups).replace(/</g, '\\u003c');
---
<div class="feed-heading minimal profile-feed-heading">
  <h2>Respostas de @{profile.username}</h2>
  <a class="profile-show-all" href={backUrl}>{backLabel}</a>
</div>

{replyGroups.length ? (
  <>
    <div class="reply-history-list" data-reply-history></div>
    <script type="application/json" data-reply-history-data set:html={historyJson}></script>
  </>
) : (
  <p class="empty-state">Ainda não há respostas publicadas por @{profile.username}.</p>
)}
