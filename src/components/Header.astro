---
import LanguageSwitch from './LanguageSwitch.astro';
import { getMessages, normalizeLocale } from '../i18n';
const { compact = false } = Astro.props;
const locale = normalizeLocale(Astro.cookies.get('murmurinho-language')?.value);
const t = getMessages(locale);
---
<header class:list={['topbar', { compact }]}> 
  <a class="brand" href="/" aria-label={`${t.site.title}, ${t.common.home}`}>
    <span class="brand-mark">m</span>
    <span>{t.site.title}</span>
  </a>
  <nav class="topbar-actions" aria-label="Navigation">
    <a class="nav-link direct-nav" href="/directs" aria-label="Bilhetes">
      <svg class="direct-nav-icon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M4.75 5.75h14.5a1.5 1.5 0 0 1 1.5 1.5v9.5a1.5 1.5 0 0 1-1.5 1.5H4.75a1.5 1.5 0 0 1-1.5-1.5v-9.5a1.5 1.5 0 0 1 1.5-1.5Z" />
        <path d="m4 7 8 6 8-6" />
      </svg>
      <span>Bilhetes</span>
      <span class="direct-badge" data-direct-badge hidden></span>
    </a>
    <a class="header-user" href="/perfil" data-own-profile-link aria-label={t.common.profile}>
      <span class="avatar header-user-avatar" data-user-avatar>MU</span>
      <span class="header-user-name" data-user-name>{t.common.profile}</span>
    </a>
    <LanguageSwitch />
    <button class="icon-button" type="button" data-theme-toggle aria-label="Theme">◐</button>
    <button class="button ghost small" type="button" data-logout>{t.common.logout}</button>
  </nav>
</header>
