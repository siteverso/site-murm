<section class="composer panel" aria-labelledby="composer-title">
  <div class="avatar" data-user-avatar>DM</div>
  <form data-composer>
    <label id="composer-title" for="murmur-text">O que está murmurando?</label>
    <textarea id="murmur-text" name="text" maxlength="420" placeholder="Escreva um murmúrio..." required></textarea>
    <div class="composer-footer">
      <span class="char-count"><strong data-char-count>0</strong>/420</span>
      <button class="button primary" type="submit">Murmurar</button>
    </div>
  </form>
</section>
