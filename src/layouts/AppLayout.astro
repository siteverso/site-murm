---
import '../styles/global.css';
import { getMessages, normalizeLocale, type Locale } from '../i18n';
import { currentUser } from '../lib/server/session';

const requestedLocale = Astro.cookies.get('murmurinho-language')?.value;
const locale: Locale = normalizeLocale(requestedLocale);
const messages = getMessages(locale);
const {
  title = messages.site.title,
  description = messages.site.description,
  auth = true,
} = Astro.props;

if (auth) {
  const user = await currentUser(Astro);

  if (!user) {
    return Astro.redirect('/login');
  }
}

const clientMessages = JSON.stringify(messages).replace(/</g, '\\u003c');
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const match = document.cookie.match(/(?:^|; )murmurinho-theme=([^;]+)/);
        const saved = match ? decodeURIComponent(match[1]) : '';
        const theme = saved || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
      })();
    </script>
    <script is:inline set:html={`window.__MURMUR_I18N__ = ${clientMessages}; window.__MURMUR_LOCALE__ = ${JSON.stringify(locale)};`} />
  </head>
  <body data-auth-required={auth ? 'true' : 'false'}>
    <slot />
    <script is:inline src="/app.js?v=20260711-2"></script>
  </body>
</html>
