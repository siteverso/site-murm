---
import '../styles/global.css';
import { getMessages, normalizeLocale, type Locale } from '../i18n';
import { TEXT_LIMIT } from '../lib/config/text';

const requestedLocale = Astro.cookies.get('murmurinho-language')?.value;
const locale: Locale = normalizeLocale(requestedLocale);
const messages = getMessages(locale);
const {
  title = messages.site.title,
  description = messages.site.description,
  auth = true,
} = Astro.props;

const clientMessages = JSON.stringify(messages).replace(/</g, '\\u003c');
const clientTextLimit = JSON.stringify(TEXT_LIMIT);
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const match = document.cookie.match(/(?:^|; )murmurinho-theme=([^;]+)/);
        const saved = match ? decodeURIComponent(match[1]) : '';
        const aliases = { light: 'pearl', dark: 'graphite' };
        const allowed = ['graphite', 'graphite-bright', 'pearl', 'ocean', 'forest', 'sunset', 'rose', 'purple'];
        const candidate = aliases[saved] || saved;
        const theme = allowed.includes(candidate) ? candidate : 'graphite';
        document.documentElement.dataset.theme = theme;
      })();
    </script>
    <script is:inline set:html={`window.__MURMUR_I18N__ = ${clientMessages}; window.__MURMUR_LOCALE__ = ${JSON.stringify(locale)}; window.__MURMUR_TEXT_LIMIT__ = ${clientTextLimit};`} />
  </head>
  <body data-auth-required={auth ? 'true' : 'false'}>
    <slot />
    <script type="module" is:inline src="/app.js?v=20260713-grafite-claro-1"></script>
  </body>
</html>
