---
import AppLayout from '../layouts/AppLayout.astro';
import Header from '../components/Header.astro';
import FeedBoard from '../components/FeedBoard.astro';
import { getMessages, normalizeLocale } from '../i18n';
const locale = normalizeLocale(Astro.cookies.get('murmurinho-language')?.value);
const t = getMessages(locale);
---
<AppLayout title={`${t.site.title} — ${t.common.home}`}>
  <Header />
  <FeedBoard parentId={null} showRandomMurmur={true} />
  <button class="floating-action" type="button" data-new-murmur aria-label="Novo murmúrio">＋</button>
  <button class="scroll-top" type="button" data-scroll-top aria-label="Voltar ao topo">↑</button>
  <div class="toast" data-toast></div>
</AppLayout>
