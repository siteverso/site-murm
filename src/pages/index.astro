---
import AppLayout from '../layouts/AppLayout.astro';
import Header from '../components/Header.astro';
import { getMessages, normalizeLocale } from '../i18n';
const locale = normalizeLocale(Astro.cookies.get('murmurinho-language')?.value);
const t = getMessages(locale);
---
<AppLayout title={`${t.site.title} — ${t.common.home}`}>
  <Header />
  <main class="shell minimal-feed-page network-board-page">
    <div class="feed-heading minimal network-board-heading">
      <h1>{t.feed.recent}</h1>
      <div class="feed-display-controls">
        <div class="segmented-control feed-view-switch" data-feed-view-switch aria-label="Modo de visualização dos murmúrios">
        <button class="segmented-control__button feed-view-button" type="button" data-feed-view="split" aria-label="Ver em colunas" title="Colunas">
          <svg viewBox="0 0 20 20" aria-hidden="true" fill="none">
            <rect x="3" y="4" width="5" height="12" rx="1.5" stroke="currentColor" stroke-width="1.6"/>
            <rect x="12" y="4" width="5" height="12" rx="1.5" stroke="currentColor" stroke-width="1.6"/>
          </svg>
        </button>
        <button class="segmented-control__button feed-view-button" type="button" data-feed-view="list" aria-label="Ver em lista" title="Lista">
          <svg viewBox="0 0 20 20" aria-hidden="true" fill="none">
            <path d="M5 5.5h10M5 10h10M5 14.5h10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            <circle cx="3.2" cy="5.5" r=".9" fill="currentColor"/>
            <circle cx="3.2" cy="10" r=".9" fill="currentColor"/>
            <circle cx="3.2" cy="14.5" r=".9" fill="currentColor"/>
          </svg>
        </button>
        </div>
      </div>
    </div>

    <section class="network-board" data-feed-board>
      <div class="feed-view-panel split-view" data-feed-view-panel="split" data-feed-columns></div>

      <div class="feed-view-panel list-view" data-feed-view-panel="list" hidden>
        <section class="network-lane all-lane">
          <div class="feed lane-feed lane-feed-list" data-feed-all-list></div>
        </section>
      </div>
    </section>
  </main>
  <button class="floating-action" type="button" data-new-murmur aria-label="Novo murmúrio">＋</button>
  <button class="scroll-top" type="button" data-scroll-top aria-label="Voltar ao topo">↑</button>
  <div class="toast" data-toast></div>
</AppLayout>
