---
import AppLayout from '../layouts/AppLayout.astro';
import Header from '../components/Header.astro';
import { getMessages, normalizeLocale } from '../i18n';
const locale = normalizeLocale(Astro.cookies.get('murmurinho-language')?.value);
const t = getMessages(locale);
---
<AppLayout title={`${t.site.title} — ${t.common.home}`}>
  <Header />
  <main class="shell minimal-feed-page network-board-page">
    <div class="feed-heading minimal network-board-heading">
      <h1>{t.feed.recent}</h1>
    </div>

    <section class="network-board">
      <section class="network-lane male-lane">
        <div class="lane-inline-head">
          <strong>Machos</strong>
          <span data-count-male>0 murmúrios</span>
        </div>
        <div class="feed lane-feed" data-feed-male></div>
      </section>

      <section class="network-lane female-lane">
        <div class="lane-inline-head">
          <strong>Fêmeas</strong>
          <span data-count-female>0 murmúrios</span>
        </div>
        <div class="feed lane-feed" data-feed-female></div>
      </section>

    </section>
  </main>
  <button class="floating-action" type="button" data-new-murmur aria-label="Novo murmúrio">＋</button>
  <button class="scroll-top" type="button" data-scroll-top aria-label="Voltar ao topo">↑</button>
  <div class="mail-pigeon" aria-hidden="true">✉</div>
  <div class="toast" data-toast></div>
</AppLayout>
