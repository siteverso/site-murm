---
import AppLayout from '../layouts/AppLayout.astro';
import Header from '../components/Header.astro';
import Composer from '../components/Composer.astro';
import { getMessages, normalizeLocale } from '../i18n';
const locale = normalizeLocale(Astro.cookies.get('murmurinho-language')?.value);
const t = getMessages(locale);
---
<AppLayout title={`${t.site.title} — ${t.common.home}`}>
  <Header />
  <main class="shell minimal-feed-page">
    <Composer />
    <div class="feed-heading minimal">
      <h1>{t.feed.recent}</h1>
      <span data-threshold-label>{t.feed.currentLimit}: 100</span>
    </div>
    <div class="feed feed-grid" data-feed></div>
  </main>
  <div class="toast" data-toast></div>
</AppLayout>
