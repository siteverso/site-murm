---
const title = 'Laboratório físico — retorno do baralho';
---
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <style>
    :root { color-scheme: dark; font-family: Inter, system-ui, sans-serif; background: #0d0f13; color: #f5f7fb; }
    * { box-sizing: border-box; }
    body { margin: 0; min-height: 100dvh; overflow: hidden; background: radial-gradient(circle at 50% 12%, #252b36 0, #11151b 54%, #090b0f 100%); }
    main { min-height: 100dvh; display: grid; grid-template-columns: minmax(340px, 410px) minmax(0, 1fr); gap: 18px; padding: 18px; }
    .workspace { grid-column: 2; min-width: 0; display: grid; grid-template-rows: auto 1fr auto; gap: 14px; }
    header { max-width: 900px; }
    h1 { margin: 0 0 6px; font-size: clamp(1.3rem, 2vw, 1.9rem); }
    p { margin: 0; color: #aeb5c2; }
    .stage { position: relative; min-height: 0; display: grid; place-items: center; overflow: visible; perspective: 1600px; border: 1px solid rgba(255,255,255,.08); border-radius: 28px; background: rgba(255,255,255,.018); }
    .stage::before { content: ''; position: absolute; inset: 50% auto auto 50%; width: 12px; height: 12px; border-radius: 50%; background: rgba(255,255,255,.18); transform: translate(-50%,-50%); box-shadow: 0 0 0 1px rgba(255,255,255,.08), 0 0 36px rgba(255,255,255,.08); }
    .card { width: min(700px, calc(100vw - 470px)); min-height: 350px; padding: 28px; border: 1px solid rgba(255,255,255,.13); border-radius: 26px; background: linear-gradient(145deg, rgba(38,43,54,.99), rgba(22,25,32,.99)); box-shadow: 0 34px 100px rgba(0,0,0,.45); cursor: grab; touch-action: none; user-select: none; transform-style: preserve-3d; will-change: transform; }
    .card:active { cursor: grabbing; }
    .card.is-returning { pointer-events: none; }
    .tag { display: inline-flex; padding: 7px 10px; border-radius: 999px; background: rgba(255,255,255,.07); font-weight: 800; font-size: .8rem; }
    .copy { margin-top: 34px; font-size: clamp(1.1rem, 2.3vw, 1.7rem); line-height: 1.5; color: #f7f8fb; }
    .quick-controls { display: flex; gap: 10px; flex-wrap: wrap; }
    button { border: 1px solid rgba(255,255,255,.14); border-radius: 12px; padding: 10px 14px; color: inherit; background: rgba(255,255,255,.06); font: inherit; font-weight: 750; cursor: pointer; }
    button:hover { background: rgba(255,255,255,.11); }
    .status { margin-top: 10px; min-height: 1.5em; font-family: ui-monospace, SFMono-Regular, Consolas, monospace; font-size: .78rem; color: #9fe4b7; }
    aside { grid-column: 1; grid-row: 1; min-height: 0; overflow: auto; padding: 16px; border: 1px solid rgba(255,255,255,.09); border-radius: 24px; background: rgba(13,16,21,.88); backdrop-filter: blur(18px); }
    aside h2 { margin: 0 0 14px; font-size: 1.05rem; }
    fieldset { margin: 0 0 14px; padding: 12px; border: 1px solid rgba(255,255,255,.09); border-radius: 16px; }
    legend { padding: 0 7px; color: #cbd2de; font-size: .78rem; font-weight: 850; text-transform: uppercase; letter-spacing: .06em; }
    .control { display: grid; grid-template-columns: minmax(0, 1fr) 92px; gap: 8px 10px; align-items: center; margin: 12px 0; }
    .control label { color: #c5ccd7; font-size: .82rem; font-weight: 700; }
    .control output { display: none; }
    input[type="range"] { grid-column: 1; width: 100%; accent-color: currentColor; }
    .control-number { grid-column: 2; grid-row: 1 / span 2; align-self: end; min-height: 38px; text-align: right; font: 750 .8rem ui-monospace, monospace; }
    .control-number:focus { outline: 2px solid rgba(159,228,183,.5); outline-offset: 1px; border-color: rgba(159,228,183,.55); }
    .control-unit { position: absolute; pointer-events: none; opacity: .55; }
    .control label { grid-column: 1; }
    .control select { grid-column: 1 / -1; }
    input[type="number"], select, input[type="text"] { width: 100%; min-height: 36px; padding: 7px 9px; border: 1px solid rgba(255,255,255,.12); border-radius: 9px; color: #fff; background: rgba(255,255,255,.05); }
    .panel-actions { position: sticky; bottom: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 8px; padding-top: 12px; background: linear-gradient(transparent, #0d1015 26%); }
    .panel-actions button:first-child { background: rgba(255,255,255,.1); }
    .json { margin-top: 10px; padding: 10px; border-radius: 12px; background: #090b0f; color: #aee7bd; font: .72rem/1.45 ui-monospace, monospace; white-space: pre-wrap; word-break: break-word; }
    @media (max-width: 980px) {
      body { overflow: auto; }
      main { grid-template-columns: 1fr; }
      aside { grid-column: 1; grid-row: 1; max-height: none; }
      .workspace { grid-column: 1; grid-row: 2; }
      .card { width: min(700px, calc(100vw - 48px)); }
      .stage { min-height: 560px; }
    }
  </style>
</head>
<body>
  <main>
    <aside>
      <h2>Parâmetros físicos</h2>
      <form data-physics-form>
        <fieldset>
          <legend>Posição inicial</legend>
          <div class="control"><label for="x">Deslocamento X</label><output data-out="x"></output><input id="x" name="x" type="range" min="-360" max="360" step="1" value="150"></div>
          <div class="control"><label for="y">Deslocamento Y</label><output data-out="y"></output><input id="y" name="y" type="range" min="-260" max="260" step="1" value="40"></div>
          <div class="control"><label for="directionDeg">Direção adicional</label><output data-out="directionDeg"></output><input id="directionDeg" name="directionDeg" type="range" min="-180" max="180" step="1" value="0"></div>
        </fieldset>

        <fieldset>
          <legend>Tempo e dinâmica</legend>
          <div class="control"><label for="duration">Duração base</label><output data-out="duration"></output><input id="duration" name="duration" type="range" min="160" max="1600" step="10" value="620"></div>
          <div class="control"><label for="distanceFactor">Fator por distância</label><output data-out="distanceFactor"></output><input id="distanceFactor" name="distanceFactor" type="range" min="0" max="2" step="0.01" value="0.62"></div>
          <div class="control"><label for="velocityX">Velocidade X</label><output data-out="velocityX"></output><input id="velocityX" name="velocityX" type="range" min="-1600" max="1600" step="10" value="0"></div>
          <div class="control"><label for="velocityY">Velocidade Y</label><output data-out="velocityY"></output><input id="velocityY" name="velocityY" type="range" min="-1600" max="1600" step="10" value="0"></div>
          <div class="control"><label for="accelerationX">Aceleração X</label><output data-out="accelerationX"></output><input id="accelerationX" name="accelerationX" type="range" min="-3000" max="3000" step="20" value="0"></div>
          <div class="control"><label for="accelerationY">Aceleração Y</label><output data-out="accelerationY"></output><input id="accelerationY" name="accelerationY" type="range" min="-3000" max="3000" step="20" value="0"></div>
          <div class="control"><label for="damping">Amortecimento</label><output data-out="damping"></output><input id="damping" name="damping" type="range" min="0" max="1" step="0.01" value="0.76"></div>
        </fieldset>

        <fieldset>
          <legend>3D e rotação</legend>
          <div class="control"><label for="depth">Profundidade Z</label><output data-out="depth"></output><input id="depth" name="depth" type="range" min="-60" max="100" step="1" value="18"></div>
          <div class="control"><label for="lift">Elevação 3D</label><output data-out="lift"></output><input id="lift" name="lift" type="range" min="0" max="80" step="1" value="16"></div>
          <div class="control"><label for="rotateX">Ângulo X</label><output data-out="rotateX"></output><input id="rotateX" name="rotateX" type="range" min="-35" max="35" step="0.5" value="0"></div>
          <div class="control"><label for="rotateY">Ângulo Y</label><output data-out="rotateY"></output><input id="rotateY" name="rotateY" type="range" min="-35" max="35" step="0.5" value="0"></div>
          <div class="control"><label for="rotateZ">Ângulo Z</label><output data-out="rotateZ"></output><input id="rotateZ" name="rotateZ" type="range" min="-45" max="45" step="0.5" value="6"></div>
          <div class="control"><label for="angularVelocity">Velocidade angular</label><output data-out="angularVelocity"></output><input id="angularVelocity" name="angularVelocity" type="range" min="-180" max="180" step="1" value="0"></div>
          <div class="control"><label for="scale">Escala inicial</label><output data-out="scale"></output><input id="scale" name="scale" type="range" min="0.8" max="1.2" step="0.005" value="1"></div>
        </fieldset>

        <fieldset>
          <legend>Retorno e elasticidade</legend>
          <div class="control"><label for="overshoot">Overshoot</label><output data-out="overshoot"></output><input id="overshoot" name="overshoot" type="range" min="0" max="0.16" step="0.001" value="0.055"></div>
          <div class="control"><label for="overshootMaxX">Overshoot máximo X</label><output data-out="overshootMaxX"></output><input id="overshootMaxX" name="overshootMaxX" type="range" min="0" max="40" step="1" value="12"></div>
          <div class="control"><label for="overshootMaxY">Overshoot máximo Y</label><output data-out="overshootMaxY"></output><input id="overshootMaxY" name="overshootMaxY" type="range" min="0" max="40" step="1" value="9"></div>
          <div class="control"><label for="approachOffset">Momento da aproximação</label><output data-out="approachOffset"></output><input id="approachOffset" name="approachOffset" type="range" min="0.35" max="0.86" step="0.01" value="0.72"></div>
          <div class="control"><label for="overshootOffset">Momento do overshoot</label><output data-out="overshootOffset"></output><input id="overshootOffset" name="overshootOffset" type="range" min="0.74" max="0.98" step="0.01" value="0.9"></div>
          <div class="control"><label for="easing">Curva de aceleração</label><output></output><select id="easing" name="easing"><option value="cubic-bezier(.18,.82,.22,1)">Suave padrão</option><option value="cubic-bezier(.16,1,.3,1)">Fluido forte</option><option value="cubic-bezier(.22,.75,.24,1)">Natural lento</option><option value="cubic-bezier(.34,1.25,.64,1)">Elástico</option><option value="ease-out">Ease out</option><option value="linear">Linear</option></select></div>
        </fieldset>

        <div class="panel-actions">
          <button type="button" data-apply>Aplicar e testar</button>
          <button type="button" data-reset>Restaurar padrão</button>
        </div>
      </form>
      <div class="json" data-json></div>
    </aside>

    <section class="workspace">
      <header>
        <h1>Laboratório físico do retorno</h1>
        <p>Arraste a carta e solte. Ajuste velocidade, aceleração, direção, profundidade, ângulos, overshoot, amortecimento e curva até o retorno ficar exatamente como você quer.</p>
      </header>

      <section class="stage" data-stage>
        <article class="card" data-test-card>
          <span class="tag">Mesmo nó DOM</span>
          <p class="copy">Este teste usa somente a função desacoplada de retorno. Nenhuma carta é recriada.</p>
        </article>
      </section>

      <footer>
        <div class="quick-controls">
          <button type="button" data-test-left>Esquerda</button>
          <button type="button" data-test-right>Direita</button>
          <button type="button" data-test-diagonal>Diagonal</button>
          <button type="button" data-test-up>Cima</button>
          <button type="button" data-test-current>Executar parâmetros</button>
        </div>
        <div class="status" data-status>Pronto.</div>
      </footer>
    </section>

  </main>

  <script is:inline src="/js/feed/deck-return-motion.js"></script>
  <script is:inline>
    const card = document.querySelector('[data-test-card]');
    const status = document.querySelector('[data-status]');
    const form = document.querySelector('[data-physics-form]');
    const json = document.querySelector('[data-json]');
    const originalNode = card;
    let drag = null;

    const units = {
      x: 'px', y: 'px', directionDeg: '°', duration: 'ms', distanceFactor: '', velocityX: 'px/s', velocityY: 'px/s', accelerationX: 'px/s²', accelerationY: 'px/s²', damping: '', depth: 'px', lift: 'px', rotateX: '°', rotateY: '°', rotateZ: '°', angularVelocity: '°/s', scale: '', overshoot: '', overshootMaxX: 'px', overshootMaxY: 'px', approachOffset: '', overshootOffset: ''
    };

    function installDirectValueInputs() {
      form.querySelectorAll('input[type="range"]').forEach(range => {
        if (range.dataset.directInputBound === 'true') return;
        range.dataset.directInputBound = 'true';
        const number = document.createElement('input');
        number.type = 'number';
        number.className = 'control-number';
        number.dataset.numberFor = range.name;
        number.min = range.min;
        number.max = range.max;
        number.step = range.step || 'any';
        number.value = range.value;
        number.setAttribute('aria-label', `Valor direto de ${range.name}`);
        range.insertAdjacentElement('afterend', number);

        const clamp = value => {
          const numeric = Number(value);
          if (!Number.isFinite(numeric)) return Number(range.value);
          const minimum = range.min === '' ? numeric : Number(range.min);
          const maximum = range.max === '' ? numeric : Number(range.max);
          return Math.min(maximum, Math.max(minimum, numeric));
        };

        range.addEventListener('input', () => {
          number.value = range.value;
        });
        number.addEventListener('input', () => {
          const numeric = Number(number.value);
          if (!Number.isFinite(numeric)) return;
          range.value = String(clamp(numeric));
          range.dispatchEvent(new Event('input', {bubbles: true}));
        });
        number.addEventListener('change', () => {
          const value = clamp(number.value);
          range.value = String(value);
          number.value = range.value;
          range.dispatchEvent(new Event('input', {bubbles: true}));
        });
      });
    }

    function readParams() {
      const data = Object.fromEntries(new FormData(form));
      Object.keys(data).forEach(key => {
        if (key !== 'easing') data[key] = Number(data[key]);
      });
      data.minDuration = Math.max(120, data.duration - 120);
      data.maxDuration = data.duration + 320;
      return data;
    }

    function syncOutputs() {
      form.querySelectorAll('input[type="range"]').forEach(input => {
        const output = form.querySelector(`[data-out="${input.name}"]`);
        if (output) output.textContent = `${input.value}${units[input.name] || ''}`;
        const direct = form.querySelector(`[data-number-for="${input.name}"]`);
        if (direct && document.activeElement !== direct) direct.value = input.value;
      });
      json.textContent = JSON.stringify(readParams(), null, 2);
    }

    function transformFor(x, y, params = readParams()) {
      const z = params.depth;
      const rx = params.rotateX || Math.max(-10, Math.min(10, -y / 28));
      const ry = params.rotateY || Math.max(-12, Math.min(12, x / 30));
      const rz = params.rotateZ || x / 24;
      return `translate3d(${x}px, ${y}px, ${z}px) rotateX(${rx}deg) rotateY(${ry}deg) rotateZ(${rz}deg) scale(${params.scale})`;
    }

    function placeCard(x, y) {
      card.style.transform = transformFor(x, y);
    }

    async function returnCard(x, y, overrides = {}) {
      const params = {...readParams(), ...overrides};
      status.textContent = `Retornando de x=${Math.round(x)}, y=${Math.round(y)}…`;
      const sameBefore = originalNode === card;
      const result = await window.DeckReturnMotion.animateReturn(card, {
        ...params,
        x,
        y,
        fromTransform: card.style.transform || transformFor(x, y, params),
        toTransform: 'translate3d(0,0,0) rotateX(0deg) rotateY(0deg) rotateZ(0deg) scale(1)',
        clearTransform: true,
      });
      const sameAfter = originalNode === card && card.isConnected;
      status.textContent = `Concluído em ${result.duration} ms | mesmo nó: ${sameBefore && sameAfter} | frames: ${result.keyframes?.length || 0}`;
    }

    card.addEventListener('pointerdown', event => {
      window.DeckReturnMotion.cancelReturn(card);
      drag = {id: event.pointerId, sx: event.clientX, sy: event.clientY, x: 0, y: 0, history: [{x:event.clientX,y:event.clientY,t:performance.now()}]};
      card.setPointerCapture(event.pointerId);
    });

    card.addEventListener('pointermove', event => {
      if (!drag || drag.id !== event.pointerId) return;
      drag.x = event.clientX - drag.sx;
      drag.y = event.clientY - drag.sy;
      drag.history.push({x:event.clientX,y:event.clientY,t:performance.now()});
      if (drag.history.length > 8) drag.history.shift();
      placeCard(drag.x, drag.y);
    });

    function velocityFrom(history) {
      if (history.length < 2) return {velocityX:0, velocityY:0};
      const end = history.at(-1);
      const start = history[0];
      const dt = Math.max(16, end.t - start.t) / 1000;
      return {velocityX:(end.x-start.x)/dt, velocityY:(end.y-start.y)/dt};
    }

    const finish = event => {
      if (!drag || drag.id !== event.pointerId) return;
      const current = drag;
      drag = null;
      card.releasePointerCapture?.(event.pointerId);
      const velocity = velocityFrom(current.history);
      form.elements.velocityX.value = Math.round(Math.max(-1600, Math.min(1600, velocity.velocityX)));
      form.elements.velocityY.value = Math.round(Math.max(-1600, Math.min(1600, velocity.velocityY)));
      syncOutputs();
      void returnCard(current.x, current.y, velocity);
    };
    card.addEventListener('pointerup', finish);
    card.addEventListener('pointercancel', finish);

    function runPreset(x, y, extra = {}) {
      if (card.classList.contains('is-returning')) window.DeckReturnMotion.cancelReturn(card);
      form.elements.x.value = x;
      form.elements.y.value = y;
      Object.entries(extra).forEach(([key,value]) => { if (form.elements[key]) form.elements[key].value = value; });
      syncOutputs();
      placeCard(x, y);
      requestAnimationFrame(() => void returnCard(x, y, extra));
    }

    document.querySelector('[data-test-left]').addEventListener('click', () => runPreset(-190, 20, {velocityX:-420, rotateZ:-8}));
    document.querySelector('[data-test-right]').addEventListener('click', () => runPreset(190, -12, {velocityX:420, rotateZ:8}));
    document.querySelector('[data-test-diagonal]').addEventListener('click', () => runPreset(130, 110, {velocityX:260, velocityY:180, rotateX:-6, rotateY:7}));
    document.querySelector('[data-test-up]').addEventListener('click', () => runPreset(20, -180, {velocityY:-480, rotateX:9, depth:32}));
    document.querySelector('[data-test-current]').addEventListener('click', () => runPreset(Number(form.elements.x.value), Number(form.elements.y.value)));
    document.querySelector('[data-apply]').addEventListener('click', () => runPreset(Number(form.elements.x.value), Number(form.elements.y.value)));
    document.querySelector('[data-reset]').addEventListener('click', () => {
      form.reset();
      syncOutputs();
      card.style.transform = '';
      status.textContent = 'Parâmetros restaurados.';
    });
    installDirectValueInputs();
    form.addEventListener('input', syncOutputs);
    syncOutputs();
  </script>
</body>
</html>
