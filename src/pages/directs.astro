---
import AppLayout from '../layouts/AppLayout.astro';
import Header from '../components/Header.astro';
---
<AppLayout title="Directs — Murmurinho">
  <Header />
  <main class="directs-page" data-directs-page>
    <aside class="directs-sidebar panel">
      <div class="directs-sidebar-head"><h1>Bilhetes</h1><span>Directs</span></div>
      <div class="direct-list" data-direct-list></div>
    </aside>
    <section class="directs-stage panel">
      <div class="direct-empty" data-direct-empty><strong>Escolha um bilhete</strong><span>As conversas chegam como correspondência, sem cara de chat.</span></div>
      <div class="direct-stage" data-direct-stage hidden>
        <div class="direct-messages" data-direct-messages>
          <div class="direct-messages-top" data-direct-messages-top hidden>
            <button class="direct-load-more" type="button" data-load-more-direct>Carregar 20 anteriores</button>
          </div>
          <div class="direct-message-list" data-direct-message-list></div>
        </div>
        <form class="direct-form" data-direct-form>
          <textarea name="contents" maxlength="256" placeholder="Responder com outro bilhete…" required></textarea>
          <button class="direct-send-button" type="submit" aria-label="Enviar bilhete" title="Enviar bilhete">
            <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <circle cx="5" cy="10" r="1.45" fill="currentColor"/>
              <path d="M8 7.85C9.25 8.85 9.25 11.15 8 12.15" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
              <path d="M11.2 5.8C14.7 8.25 14.7 11.75 11.2 14.2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
            </svg>
          </button>
        </form>
      </div>
    </section>
  </main>
  <div class="toast" data-toast></div>
</AppLayout>
