---
import AppLayout from '../../layouts/AppLayout.astro';
import Header from '../../components/Header.astro';
import ProfileSidebar from '../../components/ProfileSidebar.astro';
import { findPublicProfileByUsername } from '../../lib/server/repositories/users';
import { requireUser } from '../../lib/server/session';
import { getMessages, normalizeLocale } from '../../i18n';

const locale = normalizeLocale(Astro.cookies.get('murmurinho-language')?.value);
const t = getMessages(locale);
const username = decodeURIComponent(Astro.params.username || '').replace(/^@/, '').trim();
const profile = username ? await findPublicProfileByUsername(username) : null;
if (!profile) return Astro.redirect('/');
const currentUser = await requireUser(Astro);
const isOwnProfile = currentUser.id === profile.id;
---
<AppLayout title={`@${profile.username} — ${t.site.title}`}>
  <Header />
  <main class="shell profile-grid public-profile-grid">
    <ProfileSidebar profile={profile} showEditAccount={isOwnProfile} labels={t.profile} />
    <section class="public-profile-content">
      <div class="feed-heading minimal profile-feed-heading"><h2>Murmúrios de @{profile.username}</h2></div>
      <div class="feed profile-feed" data-profile-feed data-profile-username={profile.username} data-feed-include-replies="true"></div>
    </section>
  </main>
  <div class="toast" data-toast></div>
</AppLayout>
