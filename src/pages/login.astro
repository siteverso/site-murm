---
import AppLayout from '../layouts/AppLayout.astro';
import LanguageSwitch from '../components/LanguageSwitch.astro';
import { getMessages, normalizeLocale } from '../i18n';

const locale = normalizeLocale(Astro.cookies.get('murmurinho-language')?.value);
const t = getMessages(locale);
const googleClientId = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID || '';
const googleEnabled = googleClientId.endsWith('.apps.googleusercontent.com');
---
<AppLayout title={`${t.login.title} — ${t.site.title}`} auth={false}>
  <main class="auth-page">
    <section class="auth-intro">
      <div class="auth-brand-row">
        <a class="brand" href="/login"><span class="brand-mark">m</span><span>{t.site.title}</span></a>
        <LanguageSwitch />
      </div>
      <div>
        <h1>{t.login.headline}</h1>
        <p>{t.login.intro}</p>
      </div>
      <small>{t.login.sober}</small>
    </section>

    <section class="auth-form-wrap">
      <div class="panel auth-card">
        <h2>{t.login.title}</h2>
        <p>{t.login.description}</p>

        {googleEnabled ? (
          <>
            <div class="google-login" data-google-login data-google-client-id={googleClientId}>
              <div class="google-button-frame" data-google-button></div>
              <p class="form-message" data-google-message></p>
            </div>
            <div class="auth-divider"><span>{t.login.or}</span></div>
            <script is:inline src="https://accounts.google.com/gsi/client" async defer></script>
          </>
        ) : (
          <div class="google-config-warning">
            Configure <code>PUBLIC_GOOGLE_CLIENT_ID</code> no arquivo <code>.env</code>.
          </div>
        )}

        <form data-login-form>
          <div class="field">
            <label for="identifier">{t.login.identifier}</label>
            <input id="identifier" name="identifier" autocomplete="username" placeholder={t.login.identifierPlaceholder} required />
          </div>
          <div class="field">
            <label for="password">{t.common.password}</label>
            <input id="password" name="password" type="password" autocomplete="current-password" minlength="6" placeholder="••••••••" required />
          </div>
          <div class="auth-links">
            <label><input type="checkbox" name="remember" checked /> {t.login.remember}</label>
            <a href="/lembrar-senha">{t.login.forgot}</a>
          </div>
          <button class="button primary full" type="submit">{t.login.submit}</button>
          <p class="form-message" data-form-message></p>
        </form>

        <div class="signup-callout">
          <span>{t.login.noAccount}</span>
          <a href="/criar-conta">{t.login.createAccount}</a>
        </div>
      </div>
    </section>
  </main>
  <div class="toast" data-toast></div>
</AppLayout>
