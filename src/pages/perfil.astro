---
import AppLayout from '../layouts/AppLayout.astro';
import Header from '../components/Header.astro';
import { getMessages, normalizeLocale } from '../i18n';
const locale = normalizeLocale(Astro.cookies.get('murmurinho-language')?.value);
const t = getMessages(locale);
---
<AppLayout title={`${t.profile.title} — ${t.site.title}`}>
  <Header />
  <main class="shell profile-grid">
    <aside class="panel profile-card">
      <div class="avatar" data-profile-avatar>MU</div>
      <h1 data-profile-username>usuario</h1>
      <span class="handle" data-profile-email>usuario@exemplo.com</span>
      <span class="profile-sex" data-profile-sex>Sexo não informado</span>
      <p class="bio" data-profile-bio></p>
      <div class="profile-stats">
        <div><strong data-profile-posts>0</strong><span>{t.profile.murmurs}</span></div>
        <div><strong data-profile-positive>0</strong><span>{t.profile.positives}</span></div>
        <div><strong data-profile-negative>0</strong><span>{t.profile.negatives}</span></div>
      </div>
    </aside>

    <div class="profile-sections">
      <section class="panel profile-edit">
        <h2>{t.profile.editTitle}</h2>
        <form data-profile-form>
          <div class="profile-identity-grid">
            <div class="field">
              <label for="username">{t.common.username}</label>
              <input id="username" name="username" maxlength="30" required />
              <small class="field-help" data-username-rule>O usuário só pode ser corrigido uma vez, após 30 dias.</small>
            </div>
            <div class="field">
              <label for="email">{t.common.email}</label>
              <input id="email" name="email" type="email" required />
              <small class="field-help" data-email-rule>O e-mail pode ser alterado uma vez a cada 30 dias.</small>
            </div>
            <div class="field sex-field">
              <label for="sexCode">Sexo</label>
              <div class="select-wrap">
                <select id="sexCode" name="sexCode"><option value="">Não informar</option><option value="M">Macho</option><option value="F">Fêmea</option></select>
              </div>
              <small class="field-help" data-sex-rule>A primeira definição é livre. Depois, somente uma correção será permitida, após 30 dias.</small>
            </div>
            <div class="field">
              <label for="regionCode">Região do Brasil</label>
              <div class="select-wrap">
                <select id="regionCode" name="regionCode">
                  <option value="">Não informar</option>
                  <option value="N">Norte</option>
                  <option value="NE">Nordeste</option>
                  <option value="CO">Centro-Oeste</option>
                  <option value="SE">Sudeste</option>
                  <option value="S">Sul</option>
                </select>
              </div>
            </div>
            <div class="field">
              <label for="columnGroupCode">Colunas da página inicial</label>
              <div class="select-wrap">
                <select id="columnGroupCode" name="columnGroupCode">
                  <option value="sex">Agrupar por sexo</option>
                  <option value="region">Agrupar por regiões do Brasil</option>
                </select>
              </div>
              <small class="field-help">Define como o modo Colunas organiza os murmúrios.</small>
            </div>
          </div>
          <div class="field"><label for="bio">{t.profile.bio}</label><textarea id="bio" name="bio" maxlength="180" rows="5"></textarea></div>
          <button class="button primary" type="submit">{t.common.save}</button>
          <p class="form-message" data-form-message></p>
        </form>
      </section>

      <section class="panel profile-edit account-access">
        <h2>{t.profile.accountTitle}</h2>
        <p data-auth-explanation></p>
        <div class="auth-methods"><strong>{t.profile.accessMethods}</strong><span data-auth-methods></span></div>
        <form data-password-form>
          <h3 data-password-title>{t.profile.definePassword}</h3>
          <p>{t.profile.passwordHelp}</p>
          <div class="field"><label for="newPassword">{t.common.newPassword}</label><input id="newPassword" name="password" type="password" minlength="6" autocomplete="new-password" required /></div>
          <div class="field"><label for="confirmNewPassword">{t.common.confirmPassword}</label><input id="confirmNewPassword" name="confirmPassword" type="password" minlength="6" autocomplete="new-password" required /></div>
          <button class="button primary" type="submit">{t.profile.definePassword}</button>
          <p class="form-message" data-form-message></p>
        </form>
      </section>
    </div>
  </main>
  <div class="toast" data-toast></div>
</AppLayout>
